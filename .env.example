# ========================================
# Newscrux Configuration
# ========================================

# LLM API key (required)
# Works with OpenRouter, llama.cpp, vLLM, Ollama, or any OpenAI-compatible API
LLM_API_KEY=your_api_key_here

# LLM API base URL (default: https://openrouter.ai/api/v1)
# Examples:
#   OpenRouter:  https://openrouter.ai/api/v1
#   llama.cpp:   http://192.168.1.111:8000/v1
#   Ollama:      http://localhost:11434/v1
#   vLLM:        http://localhost:8000/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# LLM model name (default: deepseek/deepseek-v3.2-speciale)
LLM_MODEL=deepseek/deepseek-v3.2-speciale

# --- Notification Backend (choose ONE) ---

# Option A: Pushover
# Get yours at https://pushover.net
PUSHOVER_USER_KEY=your_pushover_user_key_here
PUSHOVER_APP_TOKEN=your_pushover_app_token_here

# Option B: Gotify (self-hosted, mutually exclusive with Pushover)
# GOTIFY_URL=http://your-gotify-server:80
# GOTIFY_TOKEN=your_gotify_app_token

# RSS poll interval in minutes (default: 15)
POLL_INTERVAL_MINUTES=15

# Maximum articles to process per poll cycle (default: 10)
MAX_ARTICLES_PER_POLL=10

# arXiv papers per poll cycle (default: 15)
ARXIV_MAX_PER_POLL=15

# AI relevance filter threshold, 1-10 (default: 6)
RELEVANCE_THRESHOLD=6

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
